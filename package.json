{
	"name": "odyssey",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"description": "Typed, evidence-led Hyperchart report engine with a deterministic self-contained HTML renderer.",
	"type": "module",
	"scripts": {
		"check": "biome check .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"render:example": "mkdir -p artifacts && DOCUMENT_FILE=examples/eink/report-document.json OUTPUT_PATH=artifacts/eink-report.html tsx engine/render-report.ts",
		"test:chart": "tsx --test tests/mock-run.test.ts",
		"test:scripts": "tsx --test tests/scripts-and-guards.test.ts tests/visual-input-retry-budget.test.ts",
		"test:workflow-fixture": "tsx tests/write-fixture.ts",
		"typecheck": "tsc --noEmit",
		"test": "npm run typecheck && npm run test:chart && npm run test:scripts && npm run test:workflow-fixture"
	},
	"dependencies": {
		"@surprisal/hyperchart": "file:../pi-hyperchart/packages/hyperchart",
		"echarts": "^6.0.0",
		"playwright": "^1.61.1",
		"tsx": "^4.23.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@types/node": "^26.1.1",
		"typescript": "^7.0.2"
	}
}

{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noEmit": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["chart.ts", "contracts/**/*.ts", "engine/**/*.ts", "scripts/**/*.ts", "guards/**/*.ts", "tests/**/*.ts"]
}
